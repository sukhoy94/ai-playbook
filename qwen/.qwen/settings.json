{
  "model": {
    "name": "qwen3-coder-plus",
    "maxSessionTurns": -1,
    "generationConfig": {
      "contextWindowSize": 128000,
      "enableCacheControl": true
    }
  },
  "tools": {
    "approvalMode": "default",
    "useRipgrep": true
